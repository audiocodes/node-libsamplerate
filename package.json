{
    "name": "libsamplerate",
    "version": "2.1.0",
    "description": "Native bindings for libsamplerate",
    "main": "index.js",
    "license": "MIT",
    "keywords": [
        "libsamplerate",
        "samplerate",
        "audio",
        "sample",
        "rate",
        "convert",
        "resample",
        "downsample",
        "upsample",
        "n-api",
        "node-addon-api",
        "cmake-js",
        "pkg-prebuilds",
        "S16_LE",
        "S32_LE",
        "pcm",
        "wav"
    ],
    "scripts": {
        "install": "pkg-prebuilds-verify ./binding-options.js || cmake-js compile -p 4",
        "test": "nyc mocha test/*.test.js",
        "lint": "eslint",
        "build:dev": "cmake-js build --debug -p 4",
        "build": "cmake-js build -p 4",
        "prebuild": "node ./scripts/pkg-prebuild.js",
        "build:tsc": "tsc",
        "prepack": "npx tsc",
        "pretest": "npx tsc",
        "rebuild:dev": "cmake-js rebuild --debug -p 4",
        "rebuild": "cmake-js rebuild -p 4",
        "clean": "cmake-js clean"
    },
    "dependencies": {
        "cmake-js": "^7.3.1",
        "node-addon-api": "^8.6.0",
        "pkg-prebuilds": "^1.0.0"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "repository": "github:audiocodes/node-libsamplerate",
    "bugs": {
        "url": "https://github.com/audiocodes/node-libsamplerate/issues"
    },
    "homepage": "https://github.com/audiocodes/node-libsamplerate#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/node22": "^22.0.5",
        "@types/node": "^24.12.0",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "mocha": "^11.7.5",
        "nyc": "^18.0.0",
        "sinon": "^21.0.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "files": [
        "index.js",
        "index.d.ts",
        "prebuilds/**",
        "binding-options.js",
        "src/**",
        "CMakeLists.txt",
        "LICENSE"
    ],
    "nyc": {
        "extension": [
            ".ts"
        ],
        "exclude": [
            "example.js",
            "waveheader.js",
            "test/*.js"
        ]
    }
}

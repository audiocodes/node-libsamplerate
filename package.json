{
    "name": "libsamplerate",
    "version": "2.0.4",
    "description": "Native bindings for libsamplerate",
    "main": "index.js",
    "license": "MIT",
    "keywords": [
        "libsamplerate",
        "samplerate",
        "audio",
        "sample",
        "rate",
        "convert",
        "resample",
        "downsample",
        "upsample",
        "n-api",
        "node-addon-api",
        "node-gyp",
        "S16_LE",
        "S32_LE",
        "pcm",
        "wav"
    ],
    "scripts": {
        "install": "node-gyp-build",
        "test": "nyc mocha test/*.test.js",
        "lint": "eslint",
        "build:dev": "node-gyp rebuild --debug --jobs max",
        "build": "node-gyp rebuild --jobs max",
        "prebuild": "prebuildify --napi --strip --tag-libc --name libsamplerate",
        "build:tsc": "tsc",
        "prepack": "npx tsc",
        "pretest": "npx tsc",
        "rebuild:dev": "node-gyp rebuild --debug --jobs max",
        "rebuild": "node-gyp rebuild --jobs max",
        "clean": "node-gyp clean"
    },
    "dependencies": {
        "node-addon-api": "^8.6.0",
        "node-gyp-build": "^4.8.4"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "repository": "github:audiocodes/node-libsamplerate",
    "bugs": {
        "url": "https://github.com/audiocodes/node-libsamplerate/issues"
    },
    "homepage": "https://github.com/audiocodes/node-libsamplerate#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.4.0",
        "@tsconfig/node20": "^20.1.9",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "mocha": "^11.7.5",
        "node-gyp": "^12.2.0",
        "nyc": "^18.0.0",
        "prebuildify": "^6.0.1",
        "sinon": "^21.0.2",
        "typescript": "^5.9.3"
    },
    "gypfile": true,
    "files": [
        "index.js",
        "index.d.ts",
        "prebuilds/**",
        "binding.gyp",
        "deps/libsamplerate/include/**",
        "deps/libsamplerate/src/**",
        "src/**",
        "LICENSE"
    ],
    "nyc": {
        "extension": [
            ".ts"
        ],
        "exclude": [
            "example.js",
            "waveheader.js",
            "test/*.js"
        ]
    }
}
